      <Action Name="verify" IsBound="false">
        <Parameter Name="deliveryOrder" Type="Edm.String"/>
        <Parameter Name="imageUrl" Type="Edm.String"/>
        <Parameter Name="channel" Type="Edm.String"/>
        <ReturnType Type="Edm.String"/>
      </Action>
      <Annotations Target="AgentProxyService.verify()/channel">
        <Annotation Term="Core.OptionalParameter">
          <Record Type="Core.OptionalParameterType">
            <PropertyValue Property="DefaultValue" String="web"/>
          </Record>
        </Annotation>
      </Annotations>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>